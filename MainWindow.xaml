<Window x:Class="PCConsoleMode.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PCConsoleMode"
        mc:Ignorable="d"
        Title="PCConsoleMode" Height="700" Width="1000"
        MinWidth="600" MinHeight="450"
        Icon="pack://application:,,,/icons/1-05_icon-icons.com_69204.ico">
    <!-- FIX #4: MinWidth/MinHeight prevent the window from being resized to a broken size. -->

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--
            FIX #2: Toolbar split into two rows so it doesn't clip at smaller window widths.
            Row 0: action buttons + status.
            Row 1: checkboxes + auto-start indicator.
            FIX #3: StatusText is now Bold and colored via code-behind (green=Running, red=Error, gray=Stopped).
        -->
        <StackPanel Orientation="Vertical" Margin="0,0,0,8">
            <!-- Row 0: buttons and status -->
            <WrapPanel Margin="0,0,0,4">
                <Button x:Name="StartStopButton" Width="130" Height="28" Click="StartStopButton_Click">Start Monitoring</Button>
                <Button x:Name="SaveButton" Width="70" Height="28" Margin="8,0,0,0" Click="SaveButton_Click">Save</Button>
                <TextBlock x:Name="StatusText" Margin="12,0,0,0" VerticalAlignment="Center"
                           FontWeight="Bold" Foreground="Gray">Stopped</TextBlock>
            </WrapPanel>
            <!-- Row 1: checkboxes and auto-start indicator -->
            <WrapPanel>
                <CheckBox x:Name="MinimizeToTrayCheck" Margin="0,4,0,0" VerticalAlignment="Center" IsChecked="True">Minimize to tray on close</CheckBox>
                <CheckBox x:Name="RunAtStartupCheck" Margin="12,4,0,0" VerticalAlignment="Center"
                          Checked="RunAtStartupCheck_Checked" Unchecked="RunAtStartupCheck_Unchecked">Run at startup</CheckBox>
                <TextBlock x:Name="AutoStartIndicator" Margin="12,4,0,0" VerticalAlignment="Center"
                           Foreground="Gray" TextWrapping="Wrap">Monitoring will NOT auto-start on next launch</TextBlock>
            </WrapPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,8">

            <GroupBox Header="Controller" Margin="0,4">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" Margin="4" Foreground="Gray">
                        Select the Bluetooth controller to watch for connection state.
                        The watcher will react when this device connects or disconnects.
                        Use Refresh to update the list of paired/recognized controllers.
                    </TextBlock>
                    <WrapPanel Margin="0,4">
                        <TextBlock Width="140" VerticalAlignment="Center">Controller:</TextBlock>
                        <!--
                            FIX #9: ComboBox shows a placeholder item and is disabled while
                            the BT device list is loading (toggled in code-behind).
                        -->
                        <ComboBox x:Name="ControllerCombo" Width="400" IsEnabled="False" />
                        <Button x:Name="RefreshBtButton" Width="80" Margin="8,0,0,0" Click="RefreshBtButton_Click">Refresh</Button>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Audio" Margin="0,4">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" Margin="4" Foreground="Gray">
                        Configure which audio devices should be selected when switching to game or desktop mode.
                        Refresh to enumerate available output devices.
                        You can pick different devices for game and desktop modes.
                    </TextBlock>
                    <WrapPanel Margin="0,4">
                        <TextBlock Width="140" VerticalAlignment="Center">Game Audio Device:</TextBlock>
                        <!--
                            FIX #9: Same loading pattern for audio combos.
                        -->
                        <ComboBox x:Name="GameAudioCombo" Width="400"
                                  DisplayMemberPath="Display" SelectedValuePath="Id"
                                  IsEnabled="False" />
                        <Button x:Name="RefreshAudioButton" Width="80" Margin="8,0,0,0" Click="RefreshAudioButton_Click">Refresh</Button>
                    </WrapPanel>
                    <WrapPanel Margin="0,4">
                        <TextBlock Width="140" VerticalAlignment="Center">Desktop Audio Device:</TextBlock>
                        <ComboBox x:Name="DesktopAudioCombo" Width="400"
                                  DisplayMemberPath="Display" SelectedValuePath="Id"
                                  IsEnabled="False" />
                        <Button x:Name="RefreshDesktopButton" Width="80" Margin="8,0,0,0" Click="RefreshDesktopButton_Click">Refresh</Button>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Launch program" Margin="0,4">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" Margin="4" Foreground="Gray">
                        Configure which program should be launched when the controller connects.
                        By default the app will launch Steam in Big Picture mode.
                        Use "Custom" to point to another executable and provide command-line arguments.
                    </TextBlock>
                    <WrapPanel Margin="0,4">
                        <TextBlock Width="140" VerticalAlignment="Center">Program:</TextBlock>
                        <ComboBox x:Name="ProgramChoice" Width="140" SelectionChanged="ProgramChoice_SelectionChanged">
                            <ComboBoxItem>Steam</ComboBoxItem>
                            <ComboBoxItem>Custom</ComboBoxItem>
                        </ComboBox>
                        <!--
                            FIX #6: Placeholder watermark on the path textbox via a relative
                            style — shows hint text when the box is empty and unfocused.
                        -->
                        <Grid Width="240" Margin="8,0,0,0">
                            <TextBox x:Name="SteamPathText" />
                            <TextBlock IsHitTestVisible="False" Text="Path to executable…"
                                       Foreground="LightGray" Margin="3,0,0,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SteamPathText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button x:Name="BrowseSteamButton" Width="80" Margin="8,0,0,0" Click="BrowseSteamButton_Click">Browse…</Button>
                    </WrapPanel>
                    <WrapPanel Margin="0,4">
                        <TextBlock Width="140" VerticalAlignment="Center">Program Args:</TextBlock>
                        <TextBox x:Name="ProgramArgsText" Width="520" />
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <!-- Advanced settings -->
            <GroupBox Margin="0,8,0,0">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Advanced settings" FontWeight="Bold" VerticalAlignment="Center"/>
                        <!-- FIX #8: FlatToggleButton style removes the default button chrome. -->
                        <Button x:Name="AdvancedToggleIcon" Width="20" Height="20" Margin="8,0,0,0"
                                Style="{StaticResource FlatToggleButton}"
                                Click="ToggleAdvancedButton_Click">▶</Button>
                    </StackPanel>
                </GroupBox.Header>
                <StackPanel x:Name="AdvancedContent" Visibility="Collapsed">
                    <TextBlock TextWrapping="Wrap" Margin="4" Foreground="Gray">
                        Retry and debounce tuning.
                        <Bold>Retry Count</Bold>: how many times the app will attempt to set and verify the audio device.
                        <Bold>Retry Delay</Bold>: seconds between attempts.
                        <Bold>Debounce</Bold>: seconds to ignore opposite transitions after a mode change.
                    </TextBlock>
                    <WrapPanel Margin="0,4">
                        <TextBlock Width="120" VerticalAlignment="Center">Retry Count:</TextBlock>
                        <!--
                            FIX #5: NumericTextBox style highlights the field red if the value
                            is not a valid non-negative integer (via IsNotIntConverter).
                            PreviewTextInput restricts keypresses to digits only.
                        -->
                        <TextBox x:Name="RetryCountText" Width="60"
                                 Style="{StaticResource NumericTextBox}"
                                 PreviewTextInput="NumericTextBox_PreviewTextInput"/>
                        <TextBlock Width="150" VerticalAlignment="Center" Margin="16,0,0,0">Retry Delay (secs):</TextBlock>
                        <TextBox x:Name="RetryDelayText" Width="60"
                                 Style="{StaticResource NumericTextBox}"
                                 PreviewTextInput="NumericTextBox_PreviewTextInput"/>
                        <TextBlock Width="150" VerticalAlignment="Center" Margin="16,0,0,0">Debounce (secs):</TextBlock>
                        <TextBox x:Name="IntervalText" Width="60"
                                 Style="{StaticResource NumericTextBox}"
                                 PreviewTextInput="NumericTextBox_PreviewTextInput"/>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <!--
            FIX #7: Log TextBox — maximum line count is enforced in code-behind (LogText_TextChanged).
            The HorizontalScrollBarVisibility is set to Disabled so long lines wrap rather than scroll sideways.
        -->
        <TextBox Grid.Row="2" x:Name="LogText" IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled"
                 FontFamily="Consolas" FontSize="11"
                 TextChanged="LogText_TextChanged"/>
    </Grid>
</Window>
