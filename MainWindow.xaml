<Window x:Class="PCConsoleMode.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PCConsoleMode"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="StartStopButton" Width="110" Height="30" Click="StartStopButton_Click">Start Monitoring</Button>
            <Button x:Name="SaveButton" Width="80" Height="30" Margin="8,0,0,0" Click="SaveButton_Click">Save</Button>
            <Button x:Name="BackgroundButton" Width="140" Height="30" Margin="8,0,0,0" Click="BackgroundButton_Click">Run in Background</Button>
            <TextBlock x:Name="StatusText" Margin="12,6,0,0" VerticalAlignment="Center">Stopped</TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,8">
            <WrapPanel Margin="0,4">
                <TextBlock Width="140" VerticalAlignment="Center">Controller:</TextBlock>
                <ComboBox x:Name="ControllerCombo" Width="300" />
                <Button x:Name="RefreshBtButton" Width="80" Margin="8,0,0,0" Click="RefreshBtButton_Click">Refresh</Button>
            </WrapPanel>
            <WrapPanel Margin="0,4">
                <TextBlock Width="140" VerticalAlignment="Center">Game Audio Device:</TextBlock>
                <ComboBox x:Name="GameAudioCombo" Width="400" DisplayMemberPath="Display" SelectedValuePath="Id" />
                <Button x:Name="RefreshAudioButton" Width="80" Margin="8,0,0,0" Click="RefreshAudioButton_Click">Refresh</Button>
            </WrapPanel>
            <WrapPanel Margin="0,4">
                <TextBlock Width="140" VerticalAlignment="Center">Desktop Audio Device:</TextBlock>
                <ComboBox x:Name="DesktopAudioCombo" Width="320" DisplayMemberPath="Display" SelectedValuePath="Id" />
                <Button x:Name="RefreshDesktopButton" Width="80" Margin="8,0,0,0" Click="RefreshDesktopButton_Click">Refresh</Button>
            </WrapPanel>
            <WrapPanel Margin="0,4">
                <TextBlock Width="140" VerticalAlignment="Center">Steam Path / Args:</TextBlock>
                <TextBox x:Name="SteamPathText" Width="340" />
                <Button x:Name="BrowseSteamButton" Width="80" Margin="8,0,0,0" Click="BrowseSteamButton_Click">Browse</Button>
            </WrapPanel>
            <WrapPanel Margin="0,4">
                <TextBlock Width="140" VerticalAlignment="Center">Debounce Seconds:</TextBlock>
                <TextBox x:Name="IntervalText" Width="100" />
            </WrapPanel>
        </StackPanel>

        <TextBox Grid.Row="2" x:Name="LogText" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
    </Grid>
</Window>
